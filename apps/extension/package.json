    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.18.6",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.9.3",
