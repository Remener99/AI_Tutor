# Backend runtime for Cloud.ru Container Apps.
# Copy values into Cloud.ru Container App env vars or Secret Management.

NODE_ENV=production
PORT=8787
BACKEND_HOST=0.0.0.0

LLM_PROVIDER=openai
LLM_MOCK=false
OPENAI_BASE_URL=https://api.aitunnel.ru/v1/
OPENAI_MODEL=gpt-5.4-nano
OPENAI_API_KEY=<store-in-cloudru-secret-management>

LLM_TIMEOUT_MS=90000
PLAN_LLM_TIMEOUT_MS=150000
TUTOR_CHAT_TIMEOUT_MS=170000
MONITOR_AI_TIMEOUT_MS=20000

API_TOKEN=<pilot-api-token>
ADMIN_API_TOKEN=<admin-monitoring-token>
AI_ACCESS_TOKENS=
AI_ACCESS_TOKENS_BASE64=<base64-json-access-token-records>
AI_REVOKED_TOKEN_HASHES=
AI_HOURLY_LIMIT=80
AI_DAILY_LIMIT=300

AI_QUOTA_STORAGE=postgres
DATABASE_URL=<store-in-cloudru-secret-management>
DATABASE_SSL=true
PLAN_STORAGE_PATH=/tmp/plans.json

CORS_ORIGIN=chrome-extension://*,https://*.synergy.ru,http://localhost:1815,http://localhost:1012

# Extension build-time env for Plasmo.
PLASMO_PUBLIC_API_BASE=https://<your-container-app>.containerapps.ru
PLASMO_PUBLIC_API_TOKEN=<pilot-api-token>
